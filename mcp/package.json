{
  "name": "simmer-mcp",
  "version": "3.4.3",
  "description": "MCP server for Simmer — skill discovery, execution, autoresearch, and AI market tools",
  "type": "module",
  "bin": {
    "simmer-mcp": "./dist/mcp-server.js"
  },
  "files": [
    "dist/",
    "skills/",
    "bundled-skills/",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/mcp-server.js",
    "dev": "tsc --watch",
    "pretest": "npm run bundle-skills",
    "test": "npm run build && node --test 'tests/*.test.ts'",
    "bundle-skills": "node scripts/bundle-skills.ts",
    "prepack": "npm run bundle-skills"
  },
  "keywords": [
    "mcp",
    "simmer",
    "autoresearch",
    "prediction-markets",
    "trading",
    "experiment-loop",
    "simmer-mcp"
  ],
  "mcpName": "io.github.adlai88/simmer-mcp",
  "license": "MIT",
  "engines": {
    "node": ">=22.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0"
  }
}
