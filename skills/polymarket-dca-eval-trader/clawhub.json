{
  "emoji": "🪜",
  "status": "scaffold",
  "published": false,
  "sensitivity": "sensitive",
  "sensitivity_reason": "Prop-firm/Propr-shaped evaluation constraints and automated strategy defaults can be read as partnership or performance claims; requires Adrian approval before publication.",
  "primaryEnv": "SIMMER_API_KEY",
  "requires": {
    "env": [
      "SIMMER_API_KEY"
    ],
    "pip": [
      "simmer-sdk>=0.17.0"
    ]
  },
  "envVars": [
    {
      "name": "SIMMER_API_KEY",
      "required": true,
      "description": "Your Simmer SDK API key — get from simmer.markets/dashboard"
    },
    {
      "name": "WALLET_PRIVATE_KEY",
      "required": false,
      "description": "Only needed for external-wallet self-custody trading. Not required when using managed wallets."
    }
  ],
  "cron": null,
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "dca_eval_trader.py"
  },
  "tunables": [
    {
      "env": "SIMMER_DCA_EVAL_TOTAL_BUDGET",
      "type": "number",
      "default": 30,
      "range": [3, 500],
      "step": 1,
      "label": "Total DCA budget ($)"
    },
    {
      "env": "SIMMER_DCA_EVAL_PER_MARKET_CAP",
      "type": "number",
      "default": 50,
      "range": [3, 1000],
      "step": 5,
      "label": "Per-market cap ($)"
    },
    {
      "env": "SIMMER_DCA_EVAL_DAILY_CAP",
      "type": "number",
      "default": 100,
      "range": [3, 2500],
      "step": 10,
      "label": "Daily cap ($)"
    },
    {
      "env": "SIMMER_DCA_EVAL_STOP_LOSS_PCT",
      "type": "number",
      "default": 2.5,
      "range": [0.5, 25],
      "step": 0.5,
      "label": "Stop loss (%)"
    },
    {
      "env": "SIMMER_DCA_EVAL_TAKE_PROFIT_PCT",
      "type": "number",
      "default": 4.5,
      "range": [0.5, 50],
      "step": 0.5,
      "label": "Take profit (%)"
    },
    {
      "env": "SIMMER_DCA_EVAL_ACCOUNT_SIZE",
      "type": "number",
      "default": 10000,
      "range": [100, 250000],
      "step": 100,
      "label": "Eval account size ($)"
    }
  ]
}
