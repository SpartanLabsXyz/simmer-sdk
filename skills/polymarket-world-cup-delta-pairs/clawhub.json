{
  "emoji": "⚽",
  "primaryEnv": "SIMMER_API_KEY",
  "requires": {
    "env": ["SIMMER_API_KEY"],
    "pip": ["simmer-sdk>=0.17.0"]
  },
  "envVars": [
    {
      "name": "SIMMER_API_KEY",
      "required": true,
      "description": "Your Simmer SDK API key — get from simmer.markets/dashboard (SDK tab). Free tier works."
    }
  ],
  "cron": null,
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "world_cup_delta_pairs.py"
  },
  "tunables": [
    {
      "env": "TRADING_VENUE",
      "type": "string",
      "default": "sim",
      "enum": ["sim", "polymarket"],
      "label": "Venue — sim ($SIM, default) or polymarket (real prices). sim-first recommended."
    },
    {
      "env": "WC_DELTA_TOP",
      "type": "number",
      "default": 20,
      "range": [5, 100],
      "step": 5,
      "label": "Top N pairs to display per run"
    },
    {
      "env": "WC_DELTA_MIN",
      "type": "number",
      "default": 0.10,
      "range": [0.01, 0.50],
      "step": 0.01,
      "label": "Minimum delta threshold — pairs below this are filtered out"
    },
    {
      "env": "WC_DELTA_LIMIT",
      "type": "number",
      "default": 200,
      "range": [50, 500],
      "step": 50,
      "label": "Max WC markets to fetch per run (higher = more coverage, slower)"
    }
  ]
}
