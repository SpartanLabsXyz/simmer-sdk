{
  "emoji": "🏦",
  "primaryEnv": "SIMMER_API_KEY",
  "requires": {
    "env": [
      "SIMMER_API_KEY"
    ],
    "pip": [
      "simmer-sdk>=0.13.0"
    ]
  },
  "envVars": [
    {
      "name": "SIMMER_API_KEY",
      "required": true,
      "description": "Your Simmer SDK API key — get from simmer.markets/dashboard"
    },
    {
      "name": "WALLET_PRIVATE_KEY",
      "required": false,
      "description": "Only needed for external-wallet self-custody trading. Not required with managed wallets."
    },
    {
      "name": "MM_MARKETS",
      "required": true,
      "description": "Comma-separated Simmer market IDs to quote. Import markets first with client.import_market(url)."
    }
  ],
  "cron": null,
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "market_maker.py"
  },
  "tunables": [
    {
      "env": "MM_MARKETS",
      "type": "string",
      "default": "",
      "label": "Market IDs (comma-separated Simmer IDs)"
    },
    {
      "env": "MM_SPREAD_PCT",
      "type": "number",
      "default": 0.04,
      "range": [0.01, 0.20],
      "step": 0.01,
      "label": "Spread (fraction of price, e.g. 0.04 = 4 cent spread at 50¢)"
    },
    {
      "env": "MM_QUOTE_USDC",
      "type": "number",
      "default": 10,
      "range": [1, 500],
      "step": 5,
      "label": "USDC per side per market"
    },
    {
      "env": "MM_MAX_SKEW_PCT",
      "type": "number",
      "default": 0.30,
      "range": [0.10, 1.00],
      "step": 0.05,
      "label": "Max inventory skew (fraction of quote size before pausing one side)"
    },
    {
      "env": "MM_DRIFT_THRESHOLD",
      "type": "number",
      "default": 0.02,
      "range": [0.005, 0.10],
      "step": 0.005,
      "label": "Price drift to trigger cancel/replace (fraction)"
    },
    {
      "env": "MM_TAKER_FEE_RATE",
      "type": "number",
      "default": 0.02,
      "range": [0.005, 0.05],
      "step": 0.005,
      "label": "Taker fee rate for rebate estimation (default 2%, sports 3%)"
    },
    {
      "env": "MM_MAX_MARKETS",
      "type": "number",
      "default": 5,
      "range": [1, 20],
      "step": 1,
      "label": "Max markets to quote per run"
    }
  ]
}
